@model List<catalogo_jogos.Models.Jogo>
@inject System.Text.Encodings.Web.JavaScriptEncoder jsEncoder

@{
    ViewData["Title"] = "Registros Salvos";
    var distinctYears = ViewData["DistinctYears"] as List<int> ?? new List<int>();
    var currentFilter = ViewData["CurrentFilter"] as string;
    var currentYearFilter = ViewData["CurrentYearFilter"] as int?;
    var currentUnicos = ViewData["CurrentUnicos"] as bool?;
    var currentNaoZeradosFilter = ViewData["CurrentNaoZeradosFilter"] as bool?;
    var currentPlatinadosFilter = ViewData["CurrentPlatinadosFilter"] as bool?;
}

<style>
    html, body {
        max-width: 100%;
        overflow-x: hidden;
        background-color: #121212;
    }

    .table-custom {
        width: 100%;
        table-layout: fixed;
        border-collapse: collapse;
        color: #fff;
        background-color: #212529;
        border: 1px solid #373b3e;
    }

        .table-custom thead th {
            background-color: #212529;
            border-bottom: 2px solid #373b3e;
            font-size: 0.85rem;
            padding: 12px 4px;
            text-align: center;
        }

        .table-custom tbody td {
            background-color: #212529;
            border: 1px solid #373b3e;
            padding: 8px 4px;
            font-size: 0.9rem;
            text-align: center;
            vertical-align: middle;
        }

    .col-id {
        width: 40px;
    }

    .col-nome {
        width: 22%;
        text-align: left !important;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .col-fix {
        width: 85px;
    }

    .col-acoes {
        width: 200px;
    }
</style>

<div class="container-fluid mt-5 px-4">
    <h3 class="mb-4 text-center text-white">@ViewData["Title"]</h3>

    @* Busca *@
    <div class="mb-3 d-flex align-items-center justify-content-between flex-wrap">
        <form method="get" asp-action="ListaJogos" class="d-flex align-items-center flex-wrap">
            <label class="me-2 text-white">Buscar:</label>
            <input type="text" name="termoBusca" class="form-control me-2 mb-2" style="width: 200px;" value="@currentFilter" />
            <input type="hidden" name="unicos" value="@(currentUnicos == true ? "true" : "")" />
            <input type="hidden" name="filtroAno" value="@currentYearFilter" />
            <button type="submit" class="btn btn-primary me-2 mb-2">Buscar</button>
            <a asp-action="Estatisticas" class="btn btn-primary me-2 mb-2">Ver Estatísticas</a>
            <a asp-action="ListaJogos" class="btn btn-outline-secondary me-2 mb-2">Resetar</a>
        </form>
        <button type="submit" class="btn btn-success mb-2" form="formSalvarOrdem">Salvar Ordem</button>
    </div>

    <hr class="border-secondary" />

    @* Filtros Superiores *@
    <div class="mb-3">
        <strong class="text-white">Ordenar:</strong>
        <a asp-action="ListaJogos" asp-route-sortOrder="name" asp-route-termoBusca="@currentFilter" asp-route-filtroAno="@currentYearFilter" class="btn btn-sm btn-light border">A-Z</a>
        <span class="ms-3 text-white"><strong>Anos:</strong></span>
        @foreach (var year in distinctYears)
        {
            <a asp-action="ListaJogos" asp-route-filtroAno="@(year == currentYearFilter ? null : year)" asp-route-termoBusca="@currentFilter" asp-route-unicos="@currentUnicos" class="btn btn-sm @(year == currentYearFilter ? "btn-primary" : "btn-light border") me-1">@year</a>
        }
    </div>

    @* Outros Filtros *@
    <div class="mb-3">
        <strong class="text-white">Outros Filtros:</strong>
        <a asp-action="ListaJogos" asp-route-unicos="@(currentUnicos == true ? null : true)" asp-route-termoBusca="@currentFilter" asp-route-filtroAno="@currentYearFilter" class="btn btn-sm @(currentUnicos == true ? "btn-primary" : "btn-light border")">Únicos</a>

        <a asp-action="ListaJogos" asp-route-filtroNaoZerados="@(currentNaoZeradosFilter == true ? null : true)" asp-route-termoBusca="@currentFilter" asp-route-filtroAno="@currentYearFilter" asp-route-unicos="@currentUnicos" class="btn btn-sm @(currentNaoZeradosFilter == true ? "btn-primary" : "btn-light border")">Jogos Nunca Zerados</a>

        <a asp-action="ListaJogos" asp-route-filtroPlatinados="@(currentPlatinadosFilter == true ? null : true)" asp-route-termoBusca="@currentFilter" asp-route-filtroAno="@currentYearFilter" asp-route-unicos="@currentUnicos" class="btn btn-sm @(currentPlatinadosFilter == true ? "btn-primary" : "btn-light border")">Jogos Platinados</a>
    </div>

    @* Tabela Sólida *@
    <form asp-action="SalvarOrdemLote" method="post" id="formSalvarOrdem">
        <table class="table-custom">
            <thead>
                <tr>
                    <th class="col-id">ID</th>
                    <th class="col-nome">Nome</th>
                    <th class="col-fix">Ano Finalizado</th>
                    <th class="col-fix">Zerado Nesse Ano?</th>
                    <th style="width:95px;">Nota</th>
                    <th class="col-fix">Já Zerado?</th>
                    <th class="col-fix">Platinado?</th>
                    <th style="width:70px;">Ordem</th>
                    <th class="col-acoes">Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model)
                {
                    <tr>
                        <td>@r.Id</td>
                        <td class="col-nome" title="@r.Name">@r.Name</td>
                        <td>@r.Year</td>
                        <td>@catalogo_jogos.Helper.MappingHelper.MappingBoolean(@r.FinishedInThisYear)</td>
                        <td>@r.Grade</td>
                        <td>@catalogo_jogos.Helper.MappingHelper.MappingBoolean(@r.EverCompleted)</td>
                        <td>@catalogo_jogos.Helper.MappingHelper.MappingBoolean(@r.Platinado)</td>
                        <td><input type="number" class="form-control form-control-sm text-center" value="@r.Ordem" name="ordemValores[@r.Id]" /></td>
                        <td>
                            <div class="btn-group">
                                <a asp-action="TelaEdicao" asp-route-id="@r.Id" class="btn btn-warning btn-sm">Editar</a>
                                <button type="button" class="btn btn-danger btn-sm" onclick="excluirJogo(event, @r.Id, '@jsEncoder.Encode(r.Name)')">Excluir</button>
                                <a asp-action="Detalhar" asp-route-id="@r.Id" class="btn btn-info btn-sm">Detalhes</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </form>
</div>

@section Scripts {
    <script>
        function excluirJogo(e, id, n) {
            if (confirm("Excluir '" + n + "'?")) {
                const f = document.createElement('form');
                f.method = 'post'; f.action = '/Jogos/ExcluirJogo/' + id;
                document.body.appendChild(f); f.submit();
            }
        }
    </script>
}