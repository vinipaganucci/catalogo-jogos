@model List<catalogo_jogos.Models.Jogo>
@inject System.Text.Encodings.Web.JavaScriptEncoder jsEncoder

@{
    ViewData["Title"] = "Registros Salvos";

    var distinctYears = ViewData["DistinctYears"] as List<int> ?? new List<int>();
    var currentFilter = ViewData["CurrentFilter"] as string;
    var currentYearFilter = ViewData["CurrentYearFilter"] as int?;
    var currentSortOrder = ViewData["CurrentSortOrder"] as string;
    var currentNaoZeradosFilter = ViewData["CurrentNaoZeradosFilter"] as bool?;
    var currentPlatinadosFilter = ViewData["CurrentPlatinadosFilter"] as bool?;
    var currentUnicos = ViewData["CurrentUnicos"] as bool?;
}

<style>
    .table th {
        font-size: 0.85rem;
        vertical-align: middle;
        text-align: center;
        background-color: #f8f9fa;
    }

    .table td {
        font-size: 0.9rem;
        vertical-align: middle;
    }

    .col-nome {
        max-width: 200px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .col-acoes {
        width: 190px;
        white-space: nowrap;
        text-align: center;
    }

    .col-ordem {
        width: 70px;
    }
</style>

<div class="container-fluid px-4 mt-5">
    <h3 class="mb-4 text-center">@ViewData["Title"]</h3>

    <div class="mb-3 d-flex align-items-center justify-content-between flex-wrap">
        @* FORMULÁRIO DE BUSCA: Agora mantém filtros de Ano e Únicos *@
        <form method="get" asp-action="ListaJogos" class="d-flex align-items-center mb-2">
            <label class="me-2">Buscar:</label>
            <input type="text" name="termoBusca" class="form-control me-2" style="width: 180px;"
                   placeholder="Nome..." value="@currentFilter" />

            @* Inputs escondidos para não perder os filtros ao clicar em "Buscar" *@
            <input type="hidden" name="unicos" value="@(currentUnicos == true ? "true" : "")" />
            <input type="hidden" name="filtroAno" value="@currentYearFilter" />
            <input type="hidden" name="filtroNaoZerados" value="@(currentNaoZeradosFilter == true ? "true" : "")" />
            <input type="hidden" name="filtroPlatinados" value="@(currentPlatinadosFilter == true ? "true" : "")" />

            <button type="submit" class="btn btn-primary me-2">Buscar</button>
            <a asp-controller="Jogos" asp-action="Estatisticas" class="btn btn-primary me-2">Ver Estatísticas</a>
            <a asp-action="ListaJogos" class="btn btn-outline-secondary">Resetar</a>
        </form>

        <button type="submit" class="btn btn-success mb-2" form="formSalvarOrdem">Salvar Ordem</button>
    </div>

    <hr />

    <div class="mb-3">
        <strong>Ordenar:</strong>
        <a asp-action="ListaJogos"
           asp-route-sortOrder="name"
           asp-route-termoBusca="@currentFilter"
           asp-route-filtroAno="@currentYearFilter"
           asp-route-unicos="@currentUnicos"
           class="btn btn-sm btn-light border">A-Z</a>

        <span class="ms-3"><strong>Anos:</strong></span>
        @foreach (var year in distinctYears)
        {
            var btnClass = (year == currentYearFilter) ? "btn-primary" : "btn-light border";
            <a asp-action="ListaJogos"
               asp-route-filtroAno="@(year == currentYearFilter ? null : year)"
               asp-route-termoBusca="@currentFilter"
               asp-route-unicos="@currentUnicos"
               asp-route-filtroNaoZerados="@currentNaoZeradosFilter"
               class="btn btn-sm @btnClass">@year</a>
        }
    </div>

    <div class="mb-3">
        <strong>Filtros:</strong>
        @* BOTÃO ÚNICOS: Agora carrega a busca e o ano atual *@
        <a asp-action="ListaJogos"
           asp-route-unicos="@(currentUnicos == true ? null : true)"
           asp-route-termoBusca="@currentFilter"
           asp-route-filtroAno="@currentYearFilter"
           asp-route-filtroNaoZerados="@currentNaoZeradosFilter"
           asp-route-filtroPlatinados="@currentPlatinadosFilter"
           class="btn btn-sm @(currentUnicos == true ? "btn-primary" : "btn-light border")">Únicos</a>

        <a asp-action="ListaJogos"
           asp-route-filtroNaoZerados="@(currentNaoZeradosFilter == true ? null : true)"
           asp-route-termoBusca="@currentFilter"
           asp-route-filtroAno="@currentYearFilter"
           asp-route-unicos="@currentUnicos"
           class="btn btn-sm @(currentNaoZeradosFilter == true ? "btn-primary" : "btn-light border")">Nunca Zerados</a>

        <a asp-action="ListaJogos"
           asp-route-filtroPlatinados="@(currentPlatinadosFilter == true ? null : true)"
           asp-route-termoBusca="@currentFilter"
           asp-route-filtroAno="@currentYearFilter"
           asp-route-unicos="@currentUnicos"
           class="btn btn-sm @(currentPlatinadosFilter == true ? "btn-primary" : "btn-light border")">Platinados</a>
    </div>

    @* TABELA (Estética Mantida e Sem Scroll) *@
    @if (Model.Count == 0)
    {
        <div class="alert alert-warning text-center">Nenhum registro encontrado.</div>
    }
    else
    {
        <form asp-action="SalvarOrdemLote" method="post" id="formSalvarOrdem">
            <table class="table table-bordered table-striped table-hover w-100">
                <thead>
                    <tr>
                        <th style="width: 50px;">ID</th>
                        <th class="col-nome">Nome</th>
                        <th>Ano Finalizado</th>
                        <th>Zerado Ano?</th>
                        <th style="width: 100px;">Nota</th>
                        <th>Já Zerado?</th>
                        <th>Platinado?</th>
                        <th class="col-ordem">Ordem</th>
                        <th class="col-acoes">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        <tr>
                            <td class="text-center">@r.Id</td>
                            <td class="col-nome" title="@r.Name">@r.Name</td>
                            <td class="text-center">@r.Year</td>
                            <td class="text-center">@catalogo_jogos.Helper.MappingHelper.MappingBoolean(@r.FinishedInThisYear)</td>
                            <td class="text-center">@r.Grade</td>
                            <td class="text-center">@catalogo_jogos.Helper.MappingHelper.MappingBoolean(@r.EverCompleted)</td>
                            <td class="text-center">@catalogo_jogos.Helper.MappingHelper.MappingBoolean(@r.Platinado)</td>
                            <td>
                                <input type="number" class="form-control form-control-sm" value="@r.Ordem" name="ordemValores[@r.Id]" />
                            </td>
                            <td class="col-acoes">
                                <div class="btn-group">
                                    <a asp-action="TelaEdicao" asp-route-id="@r.Id"
                                       asp-route-termoBusca="@currentFilter"
                                       asp-route-unicos="@currentUnicos"
                                       class="btn btn-warning btn-sm">Editar</a>
                                    <button type="button" class="btn btn-danger btn-sm" onclick="excluirJogo(event, @r.Id, '@jsEncoder.Encode(r.Name)')">Excluir</button>
                                    <a asp-action="Detalhar" asp-route-id="@r.Id"
                                       asp-route-termoBusca="@currentFilter"
                                       asp-route-unicos="@currentUnicos"
                                       class="btn btn-info btn-sm">Detalhes</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </form>
    }
</div>